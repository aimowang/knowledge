# JWT Secret (Base64 encoded 256-bit key)
# 生成方法: openssl rand -base64 32
JWT_SECRET=dGVzdFNlY3JldEtleUZvclRlc3RpbmdQdXJwb3Nlc09ubHk=

# Database Password
DB_PASSWORD=root

# Redis Password (optional, leave empty if not required)
REDIS_PASSWORD=

# DashScope API Key (Alibaba Cloud)
OPENAI_API_KEY=sk-你的DashScope密钥

# DingTalk Webhook URL (optional, for alert notifications)
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# DingTalk Secret (optional)
DINGTALK_SECRET=your_secret
